# Supabase — create a free project at https://supabase.com (no credit card required)
# Settings → API → copy the Project URL and the "anon public" key
VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Financial Modeling Prep — free key at https://financialmodelingprep.com/register
# Unlocks LIVE stock prices for all 40 tracked stocks (250 free calls/day, cached 3 min).
# Leave blank to use built-in sample data instead.
VITE_FMP_KEY=your-fmp-key-here

# Alpha Vantage — free API key (email only, no card): https://www.alphavantage.co/support/#api-key
# Used for live price on individual stock detail pages (25 calls/day).
VITE_ALPHA_VANTAGE_KEY=your-alpha-vantage-key-here

# Note: CoinGecko requires no key for the free public API.
